# training artifacts and logs (keep only the companion weights ppo_embodied_agent.pth for out-of-the-box reproduction)
*.pth
!ppo_embodied_agent.pth
!ppo_embodied_agent_dyn.pth        # dev/stage1-dynamics: A-mode dynamics weights
!ppo_embodied_agent_bmode.pth      # dev/stage2-bmode: B-mode force-control weights
!ppo_embodied_agent_bmode_gamed.pth  # dev/stage2-bmode: G-1 fault-env training (emergent gaming experiment)
!ppo_embodied_agent_g2gamed.pth      # dev/stage2-bmode: G-2 fault-env training (uniquely-learned gaming experiment)
!ppo_embodied_agent_maze.pth         # dev/stage3-maze: 40×40 maze + rectangular-collision policy
*.zip
